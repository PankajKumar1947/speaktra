{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "MONGODB_URI",
        "JWT_SECRET",
        "PORT",
        "NEXT_PUBLIC_API_URL",
        "API_URL",
        "EXPO_PUBLIC_API_URL"
      ]
    }
  }
}
